<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/UI%20Toolkit/Styles/LobbyStyle.uss?fileID=7433441132597879392&amp;guid=c1ae93633323eed4e9baa1825210ea51&amp;type=3#LobbyStyle"/>
    <ui:VisualElement name="tint" style="flex-grow: 1; background-color: rgba(0, 0, 0, 0.2);">
        <ui:VisualElement name="overlay" style="flex-grow: 1; justify-content: center; align-items: center;">
            <ui:VisualElement name="container" style="flex-grow: 1; position: absolute;">
                <ui:Image source="project://database/Assets/Art/2D/Loading.png?fileID=2800000&amp;guid=47ae825ab7a93184d89d567616a490e6&amp;type=3#Loading" scale-mode="ScaleToFit" name="loading-spinner" style="transition-property: rotate; transition-duration: 472s; opacity: 1;"/>
                <ui:Label text="Loading..." name="loading-text" class="Lable" style="align-self: auto; -unity-font-style: italic; -unity-text-align: middle-center; font-size: 50px;"/>
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
