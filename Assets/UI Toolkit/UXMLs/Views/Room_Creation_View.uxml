<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/UI%20Toolkit/Styles/LobbyStyle.uss?fileID=7433441132597879392&amp;guid=c1ae93633323eed4e9baa1825210ea51&amp;type=3#LobbyStyle"/>
    <ui:VisualElement name="tint" style="flex-grow: 1; background-color: rgba(0, 0, 0, 0.4);">
        <ui:VisualElement name="container" style="flex-grow: 1;">
            <ui:Label text="Create a room" name="header" class="header" style="translate: 0 200px;"/>
            <ui:VisualElement name="container" style="background-color: rgb(128, 128, 128); margin-top: 200px; margin-right: 400px; margin-bottom: 400px; margin-left: 400px; border-top-left-radius: 10px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-bottom-left-radius: 10px; flex-direction: column; align-items: stretch; align-content: auto; justify-content: flex-start; height: 100%; padding-top: 10px; padding-right: 10px; padding-bottom: 10px; padding-left: 10px;">
                <ui:VisualElement style="flex-grow: 1; margin-left: 100px; margin-right: 100px; margin-top: 50px; margin-bottom: 50px;">
                    <ui:TextField label="Room name" placeholder-text="Pompo lo pompo" name="room-name" class="Lable"/>
                    <ui:VisualElement name="spacer" style="flex-basis: 10px;"/>
                    <ui:SliderInt label="Max Players" value="4" high-value="8" show-input-field="true" low-value="1" name="max-players" class="Lable" style="justify-content: flex-start; align-items: stretch;"/>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="bottom-container" style="flex-grow: 1; position: absolute; top: auto; left: 400px; right: 400px; bottom: 0; flex-direction: row; height: 400px; justify-content: space-between; align-items: flex-start; padding-top: 5px;">
                <ui:Button text="Back" name="back-button" style="align-items: auto; align-self: auto; font-size: 32px;"/>
                <ui:Button text="Create" enabled="true" name="create-button" style="align-items: auto; align-self: auto; font-size: 32px;"/>
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
